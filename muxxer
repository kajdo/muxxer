#!/usr/bin/env bash

SESSION="rory"
TARGET_DIR="/home/kajdo/git/pipecat_rory"
COMMAND="cd $TARGET_DIR && nix-shell"

# Check if the session already exists
tmux has-session -t $SESSION 2>/dev/null

if [ $? != 0 ]; then
    # Session does NOT exist, so create and configure it
    echo "Session '$SESSION' not found. Creating and initializing..."

    # 1. Start detached session
    tmux new-session -d -s $SESSION

    # 2. Setup first pane
    tmux send-keys -t $SESSION "$COMMAND" C-m

    # 3. Split vertically (side-by-side)
    tmux split-window -h -t $SESSION

    # 4. Setup second pane
    tmux send-keys -t $SESSION "$COMMAND" C-m
else
    echo "Session '$SESSION' already exists. Attaching..."
fi

# Finally, attach to the session
tmux attach-session -t $SESSION
