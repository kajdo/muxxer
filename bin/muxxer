#!/usr/bin/env bash

set -euo pipefail

SCRIPT_PATH="$(readlink -f "${BASH_SOURCE[0]}")"
SCRIPT_DIR="$(cd "$(dirname "$SCRIPT_PATH")/.." && pwd)"
LIB_DIR="$SCRIPT_DIR/lib"

source "$LIB_DIR/core.sh"
source "$LIB_DIR/utils/logging.sh"
source "$LIB_DIR/utils/error-handling.sh"
source "$LIB_DIR/utils/validation.sh"
source "$LIB_DIR/utils/project-detection.sh"
source "$LIB_DIR/config.sh"
source "$LIB_DIR/tmux.sh"
source "$LIB_DIR/fzf.sh"
source "$LIB_DIR/templates.sh"
source "$LIB_DIR/workflows/local.sh"
source "$LIB_DIR/workflows/newrepo.sh"

handle_session_list_mode() {
	local selected_session=""

	selected_session="$(fzf::select_session)"
	if [[ -z "$selected_session" ]]; then
		log::info "No session selected"
		exit 0
	fi

	log::info "Attaching to session '$selected_session'"
	tmux::attach "$selected_session"
}

handle_all_projects_flow() {
	local selected_directory=""
	local session_name=""

	selected_directory="$(fzf::select_all_directories)"

	if [[ -z "$selected_directory" ]]; then
		log::info "No project selected"
		exit 0
	fi

	session_name="$(tmux::sanitize_session_name "$(basename "$selected_directory")")"

	if tmux::session_exists "$session_name"; then
		log::info "Attaching to existing session '$session_name'"
		tmux::attach "$session_name"
		return $?
	fi

	log::info "Creating session '$session_name' for existing project"
	workflow::local::run "$session_name" "$selected_directory"
}

handle_new_session_flow() {
	local session_name="${1:-}"
	local selected_directory=""

	selected_directory="$(fzf::select_directory "$session_name")"

	if [[ -z "$selected_directory" ]]; then
		log::info "Selection cancelled"
		exit 0
	fi

	if [[ "$selected_directory" == "NEW REPO" ]]; then
		log::info "Starting new repo workflow"
		workflow::newrepo::run "$session_name"
		return $?
	fi

	# Sanitize session name from selected directory (not input arg)
	session_name="$(tmux::sanitize_session_name "$(basename "$selected_directory")")"
	workflow::local::run "$session_name" "$selected_directory"
}

show_help() {
	printf '%s\n' \
		"Usage: muxxer [SESSION_NAME]" \
		"" \
		"Simple (opinionated) tmux session manager." \
		"" \
		"Flags:" \
		"  -h, --help       Show this help message" \
		"  -v, --version    Show muxxer version" \
		"  --init           Initialize configuration (only if not exists)" \
		"  --force-init     Force overwrite configuration with defaults" \
		"  --sessions       List and attach to existing tmux sessions" \
		"" \
		"Examples:" \
		"  muxxer            Browse and attach to existing projects" \
		"  muxxer --sessions List and attach to tmux sessions" \
		"  muxxer myproject  Attach to or create session (filtered)" \
		"  muxxer --help     Show help" \
		"  muxxer --version  Show version" \
		"  muxxer --init     Initialize configuration" \
		"  muxxer --force-init  Reset configuration to defaults"
}

show_version() {
	printf 'muxxer %s\n' "$MUXXER_VERSION"
}

main() {
	config::setup_symlink

	local session_name=""
	local first_arg="${1:-}"
	local force_init="false"

	case "$first_arg" in
	-h|--help)
		show_help
		return 0
		;;
	-v|--version)
		show_version
		return 0
		;;
	--init)
		config::init
		log::success "Configuration initialized"
		return 0
		;;
	--force-init)
		force_init="true"
		config::init "$force_init"
		log::success "Configuration reset to defaults"
		return 0
		;;
	--sessions)
		handle_session_list_mode
		return $?
		;;
	esac

	# Setup signal handlers
	error::setup_trap

	# Initialize config (copies defaults on first run)
	config::init "false"

	if [[ $# -eq 0 ]]; then
		handle_all_projects_flow
		return $?
	fi

	session_name="$1"

	if ! validation::session_name_valid "$session_name"; then
		error::handle "Invalid session name '$session_name' (allowed: letters, numbers, underscore, dash, dot, colon)"
	fi

	session_name="$(tmux::sanitize_session_name "$session_name")"

	if tmux::session_exists "$session_name"; then
		log::info "Session '$session_name' found, attaching..."
		tmux::attach "$session_name"
		return 0
	fi

	log::info "Session '$session_name' not found, creating new..."
	handle_new_session_flow "$session_name"
}

main "$@"
